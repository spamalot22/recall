POSTGRES_DB=recall
POSTGRES_USER=recall
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=postgres://recall:change-this-database-password@recall_db:5432/recall
DRIZZLE_MIGRATIONS_DIR=./drizzle

RECALL_API_PORT=8787
JWT_ACCESS_SECRET=change-this-access-secret-to-at-least-32-characters
